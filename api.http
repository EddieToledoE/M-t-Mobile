  "password": "Gatitor1"
}

###############################################################################
# 🎓 EDUCATIONAL LEVELS
###############################################################################

### Get all educational levels
GET {{host}}/api/catalog/educational-levels
Accept: application/json

### Get educational level by ID
GET {{host}}/api/catalog/educational-levels/1
Accept: application/json

### Create educational level
POST {{host}}/api/catalog/educational-levels
Content-Type: application/json

{
  "name": "Primaria",
  "maxGrade": 6,
  "displayOrder": 1
}

### Update educational level
PUT {{host}}/api/catalog/educational-levels/1
Content-Type: application/json

{
  "name": "Primaria",
  "maxGrade": 6,
  "displayOrder": 1,
  "isActive": true
}

### Deactivate educational level
DELETE {{host}}/api/catalog/educational-levels/1

###############################################################################
# 🏫 SCHOOLS
###############################################################################

### Get all schools
GET {{host}}/api/catalog/schools
Accept: application/json

### Get schools by educational level
GET {{host}}/api/catalog/schools/by-level?educationalLevelId=1
Accept: application/json

### Get school by ID
GET {{host}}/api/catalog/schools/1
Accept: application/json

### Create school
POST {{host}}/api/catalog/schools
Content-Type: application/json

{
  "educationalLevelId": 2,
  "name": "Escuela Benito Juárez"
}

### Update school
PUT {{host}}/api/catalog/schools/1
Content-Type: application/json

{
  "name": "Escuela Benito Juárez García",
  "isActive": true
}

### Deactivate school
DELETE {{host}}/api/catalog/schools/1

