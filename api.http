###############################################################################
# 📅 CALENDAR EVENTS
###############################################################################

### Get events by date range
GET {{host}}/api/calendar/events?from=2026-02-01&to=2026-03-01
Accept: application/json

### Get upcoming events (default 7 days)
GET {{host}}/api/calendar/events/upcoming
Accept: application/json

### Get upcoming events (14 days)
GET {{host}}/api/calendar/events/upcoming?days=14
Accept: application/json

### Get event by ID
GET {{host}}/api/calendar/events/1
Accept: application/json

### Create event - Free (no relations)
POST {{host}}/api/calendar/events
Content-Type: application/json

{
  "title": "Reunión de equipo",
  "description": "Planificación semanal",
  "startAt": "2026-02-20T09:00:00",
  "endAt": "2026-02-20T10:00:00",
  "allDay": false,
  "eventType": "Other",
  "location": "Oficina",
  "remindAt": "2026-02-20T08:30:00",
  "relatedOrderId": null,
  "relatedSchoolId": null,
  "relatedStudentId": null
}

### Create event - Photo session linked to school
POST {{host}}/api/calendar/events
Content-Type: application/json

{
  "title": "Sesión fotos Secundaria 3°A",
  "description": "Fotos de graduación",
  "startAt": "2026-02-25T09:00:00",
  "endAt": "2026-02-25T14:00:00",
  "allDay": false,
  "eventType": "PhotoSession",
  "location": "Auditorio",
  "remindAt": "2026-02-24T20:00:00",
  "relatedOrderId": null,
  "relatedSchoolId": 1,
  "relatedStudentId": null
}

