Content-Type: application/json

{
  "status": "Delivered"
}

### Update order status - Cancelled
PATCH {{host}}/api/orders/1/status
Content-Type: application/json

{
  "status": "Cancelled"
}

### Delete order
DELETE {{host}}/api/orders/1

###############################################################################
# 🛒 ORDER ITEMS
###############################################################################

### Get items for order
GET {{host}}/api/orders/1/items
Accept: application/json

### Get specific item
GET {{host}}/api/orders/1/items/1
Accept: application/json

### Create item - Paquete (standard, uses PriceRule)
POST {{host}}/api/orders/1/items
Content-Type: application/json

{
  "productTypeId": 1,
  "quantity": 2,
  "finishId": 1,
  "sizeId": 1,
  "frameModelId": null,
  "colorId": null,
  "manualUnitPrice": null,
  "notes": "Paquete grande mate"
}

### Create item - Solo fotos (flexible, manual price)
POST {{host}}/api/orders/1/items
Content-Type: application/json

{
  "productTypeId": 4,
  "quantity": 5,
  "finishId": null,
  "sizeId": null,
  "frameModelId": null,
  "colorId": null,
  "manualUnitPrice": 50.00,
  "notes": "Fotos adicionales"
}

### Create item - Bastidor (with frame model + finish + color)
POST {{host}}/api/orders/1/items
Content-Type: application/json

{
  "productTypeId": 3,
  "quantity": 1,
  "finishId": 2,
  "sizeId": 3,
  "frameModelId": 1,
  "colorId": 5,
  "manualUnitPrice": null,
  "notes": "Bastidor 30x40 marco dorado"
}

### Update item
PUT {{host}}/api/orders/1/items/1
Content-Type: application/json

{
  "quantity": 3,
  "finishId": 1,
  "sizeId": 2,
  "frameModelId": null,
  "colorId": null,
  "manualUnitPrice": null,
  "notes": "Cambio a tamaño mediano"
}

### Delete item
DELETE {{host}}/api/orders/1/items/1

